{
  "version": 5,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 21,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake"
      }
    },
    {
      "name": "base-release",
      "hidden": true,
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "linux-debug",
      "inherits": "base",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "linux-release-static",
      "inherits": "base-release",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      },
      "cacheVariables": {
        "VCPKG_OVERLAY_TRIPLETS": "${sourceDir}/cmake/triplets",
        "VCPKG_TARGET_TRIPLET": "x64-linux-static"
      }
    },
    {
      "name": "windows-native-mingw64-base",
      "hidden": true,
      "inherits": "base",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "cacheVariables": {
        "VCPKG_OVERLAY_TRIPLETS": "${sourceDir}/cmake/triplets",
        "VCPKG_TARGET_TRIPLET": "x64-mingw-static",
        "CMAKE_C_COMPILER": "gcc",
        "CMAKE_CXX_COMPILER": "g++",
        "CMAKE_RC_COMPILER": "windres",
        "STMANAGER_BUILD_TESTS": "ON"
      }
    },
    {
      "name": "windows-native-mingw64-debug",
      "inherits": "windows-native-mingw64-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "windows-native-mingw64-release-static",
      "inherits": "windows-native-mingw64-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "windows-native-mingw-release-static",
      "inherits": "windows-native-mingw64-release-static"
    },
    {
      "name": "linux-cross-windows-x64-release",
      "inherits": "base-release",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      },
      "cacheVariables": {
        "VCPKG_OVERLAY_TRIPLETS": "${sourceDir}/cmake/triplets",
        "VCPKG_TARGET_TRIPLET": "x64-mingw-static",
        "VCPKG_APPLOCAL_DEPS": "OFF",
        "CMAKE_SYSTEM_NAME": "Windows",
        "CMAKE_CXX_COMPILER": "x86_64-w64-mingw32-g++",
        "CMAKE_RC_COMPILER": "x86_64-w64-mingw32-windres",
        "STMANAGER_BUILD_TESTS": "OFF"
      }
    },
    {
      "name": "linux-cross-android-arm64-release",
      "inherits": "base",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "MinSizeRel",
        "VCPKG_TARGET_TRIPLET": "arm64-android",
        "VCPKG_CHAINLOAD_TOOLCHAIN_FILE": "$env{ANDROID_NDK_HOME}/build/cmake/android.toolchain.cmake",
        "ANDROID_ABI": "arm64-v8a",
        "ANDROID_PLATFORM": "26",
        "STMANAGER_BUILD_SHARED": "ON",
        "STMANAGER_BUILD_CLI": "OFF",
        "STMANAGER_BUILD_TESTS": "OFF"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "linux-debug",
      "configurePreset": "linux-debug"
    },
    {
      "name": "linux-release-static",
      "configurePreset": "linux-release-static"
    },
    {
      "name": "windows-native-mingw64-debug",
      "configurePreset": "windows-native-mingw64-debug"
    },
    {
      "name": "windows-native-mingw64-release-static",
      "configurePreset": "windows-native-mingw64-release-static"
    },
    {
      "name": "windows-native-mingw-release-static",
      "configurePreset": "windows-native-mingw-release-static"
    },
    {
      "name": "linux-cross-windows-x64-release",
      "configurePreset": "linux-cross-windows-x64-release"
    },
    {
      "name": "linux-cross-android-arm64-release",
      "configurePreset": "linux-cross-android-arm64-release"
    }
  ],
  "testPresets": [
    {
      "name": "linux-debug",
      "configurePreset": "linux-debug",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "linux-release-static",
      "configurePreset": "linux-release-static",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "windows-native-mingw64-debug",
      "configurePreset": "windows-native-mingw64-debug",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "windows-native-mingw64-release-static",
      "configurePreset": "windows-native-mingw64-release-static",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "windows-native-mingw-release-static",
      "configurePreset": "windows-native-mingw-release-static",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
